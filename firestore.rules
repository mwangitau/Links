rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shifts can be created by any authenticated user.
    // We can make this more secure later by checking user roles if needed.
    match /shifts/{shiftId} {
      allow read, write: if request.auth != null;

      // Transactions can only be created within a shift by an authenticated user.
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}